@model IEnumerable<Library.Domain.Book>

@{
    ViewData["Title"] = "Books";
}

<h1>Books</h1>

<form method="get">
    <input type="text" name="searchString" placeholder="Search by Title or Author" value="@Context.Request.Query["searchString"]" />
    
    <select name="availability">
        <option value="">All</option>
        <option value="Available">Available</option>
        <option value="OnLoan">On Loan</option>
    </select>

    <button type="submit">Filter</button>
</form>

<table class="table">
    <thead>
        <tr>
            <th>Title</th>
            <th>Author</th>
            <th>ISBN</th>
            <th>Availability</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var book in Model)
{
    <tr>
        <td>@book.Title</td>
        <td>@book.Author</td>
        <td>@book.ISBN</td>
        <td>@(book.IsAvailable ? "Available" : "On Loan")</td>
        <td>
            <a asp-action="Edit" asp-route-id="@book.Id">Edit</a> |
            <a asp-action="Details" asp-route-id="@book.Id">Details</a> |
            <a asp-action="Delete" asp-route-id="@book.Id">Delete</a>
        </td>
    </tr>
}
    </tbody>
</table>