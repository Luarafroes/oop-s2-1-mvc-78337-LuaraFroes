@model Library.Domain.Loan

@{
    ViewData["Title"] = "Create Loan";
}

<h1>Create Loan</h1>

<form asp-action="Create">
    <div class="form-group">
        <label asp-for="BookId"></label>
        <select asp-for="BookId" class="form-control" asp-items="ViewBag.BookId"></select>
    </div>

    <div class="form-group">
        <label asp-for="MemberId"></label>
        <select asp-for="MemberId" class="form-control" asp-items="ViewBag.MemberId"></select>
    </div>

    <div class="form-group">
        <label asp-for="LoanDate"></label>
        <input asp-for="LoanDate" class="form-control" />
    </div>

    <div class="form-group">
        <label asp-for="DueDate"></label>
        <input asp-for="DueDate" class="form-control" />
    </div>

    <button type="submit" class="btn btn-primary">Create</button>
</form>

<a asp-action="Index">Back to List</a>