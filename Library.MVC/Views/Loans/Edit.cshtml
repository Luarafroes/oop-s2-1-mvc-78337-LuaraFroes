@model IEnumerable<Library.Domain.Loan>

@{
    ViewData["Title"] = "Loans";
}

<h1>Loans</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Create New Loan</a>
</p>

<table class="table">
    <thead>
        <tr>
            <th>Book</th>
            <th>Member</th>
            <th>Loan Date</th>
            <th>Due Date</th>
            <th>Status</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Book?.Title</td>
                <td>@item.Member?.Name</td>
                <td>@item.LoanDate.ToShortDateString()</td>
                <td>@item.DueDate?.ToShortDateString()</td>
                <td>
                    @if (item.ReturnedDate.HasValue)
                    {
                        <span class="text-success">Returned</span>
                    }
                    else
                    {
                        <span class="text-danger">On Loan</span>
                    }
                </td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm">Details</a>
                    @if (!item.ReturnedDate.HasValue)
                    {
                        <a asp-action="Return" asp-route-id="@item.Id" class="btn btn-success btn-sm">Mark Returned</a>
                    }
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Edit</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>