@model IEnumerable<Library.Domain.Loan>

@{
    ViewData["Title"] = "Loans";
}

<h1>Loans</h1>

<p>
    <a asp-action="Create" class="btn btn-success">Create New Loan</a>
</p>

<table class="table">
    <thead>
        <tr>
            <th>Book</th>
            <th>Member</th>
            <th>Loan Date</th>
            <th>Due Date</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@Html.DisplayFor(modelItem => item.LoanDate)</td>
                <td>@Html.DisplayFor(modelItem => item.DueDate)</td>
                <td>@item.Book.Title</td>
                <td>@item.Member.Name</td>
    @if (User.IsInRole("Admin"))
                {
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Edit</a>
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info text-white">Details</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
                        @* Mark Returned button only for active loans *@
                        @if (item.ReturnedDate == null)
                        {
                            <form asp-action="MarkReturned" method="post" style="display:inline;">
                                <input type="hidden" name="id" value="@item.Id" />
                                <button type="submit" class="btn btn-sm btn-success">Mark Returned</button>
                            </form>
                        }
                        else
                        {
                            <span class="text-success">Returned</span>
                        }
                </td>
                }
            </tr>
        }
    </tbody>
</table>